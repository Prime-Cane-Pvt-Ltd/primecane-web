# --- Frontend (build-time, safe to expose) ---
# Email signup endpoint. Defaults to the bundled Cloudflare Pages Function.
# Override only if you point the form at a different provider (Formspree, Brevo, etc.).
VITE_SIGNUP_ENDPOINT=/api/subscribe

# --- Server secret (set in Cloudflare, NOT committed, NOT prefixed VITE_) ---
# Password for downloading the signup list at /api/subscribers?key=...
# Set it in Cloudflare: Pages → Settings → Variables and Secrets → add `ADMIN_KEY`.
# ADMIN_KEY=change-me-to-a-long-random-string
